---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../utils/date";
import { siteConfig } from "../site.config";
import { tagSlug } from "../utils/tags";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const href = `/blog/${post.id}/`;
const image = post.data.heroImage ?? siteConfig.defaultImage;
---

<article class:list={["post-card", { featured }]}>
  <a class="post-card-image" href={href} aria-label={post.data.title}>
    <img src={image} alt="" loading={featured ? "eager" : "lazy"} />
  </a>
  <div class="post-card-content">
    <div class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <span>{post.data.tags[0] ?? "笔记"}</span>
    </div>
    <h2><a href={href}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="tag-row" aria-label="文章标签">
      {post.data.tags.map((tag) => (
        <a href={`/tags/${tagSlug(tag)}/`}>{tag}</a>
      ))}
    </div>
  </div>
</article>
