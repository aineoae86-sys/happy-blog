---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "../utils/date";
import { siteConfig } from "../site.config";
import { tagSlug } from "../utils/tags";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const image = post.data.heroImage ?? siteConfig.defaultImage;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={image}
  type="article"
>
  <article class="post-shell">
    <header class="post-hero">
      <div class="post-kicker">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        {post.data.updatedDate && <span>更新于 {formatDate(post.data.updatedDate)}</span>}
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row" aria-label="文章标签">
        {post.data.tags.map((tag) => (
          <a href={`/tags/${tagSlug(tag)}/`}>{tag}</a>
        ))}
      </div>
    </header>
    <figure class="post-cover">
      <img src={image} alt="" />
    </figure>
    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>
